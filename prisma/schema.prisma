generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CLIENT
  BUSINESS_OWNER
  EMPLOYEE
  SUPER_ADMIN
}

enum SubscriptionTier {
  FREE
  STANDARD
  PRO
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  RESCHEDULED
}

enum BusinessSize {
  SOLO
  TEAM
}

// ─── CATEGORIES ──────────────────────────────────────────

model Category {
  id          String     @id @default(cuid())
  name        String     @unique
  slug        String     @unique
  icon        String     @default("✂️")
  imageUrl    String?
  description String?
  isActive    Boolean    @default(true)
  order       Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  businesses  Business[]
}

// ─── USERS ───────────────────────────────────────────────

model User {
  id                  String    @id @default(cuid())
  email               String    @unique
  passwordHash        String?
  fullName            String
  phone               String?
  avatarUrl           String?
  role                UserRole  @default(CLIENT)
  preferredLanguage   String    @default("en")
  googleAccountId     String?
  googleCalendarToken String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  business         Business?       @relation("BusinessOwner")
  employeeProfile  Employee?
  bookings         Booking[]       @relation("ClientBookings")
  reviews          Review[]
  savedBusinesses  SavedBusiness[]
  sentMessages     Message[]       @relation("SentMessages")
  receivedMessages Message[]       @relation("ReceivedMessages")
  notifications    Notification[]
}

// ─── BUSINESS ────────────────────────────────────────────

model Business {
  id               String           @id @default(cuid())
  ownerId          String           @unique
  owner            User             @relation("BusinessOwner", fields: [ownerId], references: [id])
  name             String
  slug             String           @unique
  categoryId       String?
  category         Category?        @relation(fields: [categoryId], references: [id])
  categoryLegacy   String?
  description      String?
  size             BusinessSize     @default(SOLO)
  hasBooking       Boolean          @default(true)
  acceptsWalkIns   Boolean          @default(false)
  isActive         Boolean          @default(true)
  isVerified       Boolean          @default(false)
  isApproved       Boolean          @default(false)
  city             String
  province         String
  address          String?
  latitude         Float?
  longitude        Float?
  phone            String?
  email            String?
  website          String?
  instagram        String?
  facebook         String?
  subscription     SubscriptionTier @default(FREE)
  subscriptionStart DateTime?
  subscriptionEnd   DateTime?
  billingCycle     String?
  autoRenew        Boolean          @default(true)
  stripeCustomerId String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  employees     Employee[]
  media         BusinessMedia[]
  businessHours BusinessHours[]
  services      Service[]
  bookings      Booking[]
  reviews       Review[]
  savedBy       SavedBusiness[]
  messages      Message[]
  carListings   CarListing[]
  notifications Notification[]
  profileViews  ProfileView[]
}

model Employee {
  id         String    @id @default(cuid())
  userId     String?   @unique
  user       User?     @relation(fields: [userId], references: [id])
  businessId String
  business   Business  @relation(fields: [businessId], references: [id])
  name       String
  bio        String?
  avatarUrl  String?
  specialty  String?
  isActive   Boolean   @default(true)
  isAdmin    Boolean   @default(false)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  schedules EmployeeSchedule[]
  bookings  Booking[]
  media     BusinessMedia[]
}

model BusinessHours {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id])
  dayOfWeek  Int
  openTime   String
  closeTime  String
  isClosed   Boolean  @default(false)
}

model EmployeeSchedule {
  id         String   @id @default(cuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])
  dayOfWeek  Int
  openTime   String
  closeTime  String
  isClosed   Boolean  @default(false)
}

model Service {
  id          String   @id @default(cuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id])
  name        String
  description String?
  price       Float?
  priceType   String   @default("fixed")
  duration    Int?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  bookings Booking[]
  media    BusinessMedia[]
}

model BusinessMedia {
  id          String    @id @default(cuid())
  businessId  String
  business    Business  @relation(fields: [businessId], references: [id])
  employeeId  String?
  employee    Employee? @relation(fields: [employeeId], references: [id])
  serviceId   String?
  service     Service?  @relation(fields: [serviceId], references: [id])
  url         String
  publicId    String?
  type        String
  caption     String?
  isPublished Boolean   @default(false)
  order       Int       @default(0)
  createdAt   DateTime  @default(now())
}

model Booking {
  id                    String        @id @default(cuid())
  businessId            String
  business              Business      @relation(fields: [businessId], references: [id])
  clientId              String
  client                User          @relation("ClientBookings", fields: [clientId], references: [id])
  employeeId            String?
  employee              Employee?     @relation(fields: [employeeId], references: [id])
  serviceId             String?
  service               Service?      @relation(fields: [serviceId], references: [id])
  status                BookingStatus @default(PENDING)
  date                  DateTime
  startTime             String
  endTime               String?
  notes                 String?
  isWalkIn              Boolean       @default(false)
  googleCalendarEventId String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
}

model Review {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id])
  clientId   String
  client     User     @relation(fields: [clientId], references: [id])
  rating     Int
  comment    String?
  response   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model SavedBusiness {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  businessId String
  business   Business @relation(fields: [businessId], references: [id])
  createdAt  DateTime @default(now())

  @@unique([userId, businessId])
}

model Message {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id])
  senderId   String
  sender     User     @relation("SentMessages", fields: [senderId], references: [id])
  receiverId String
  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id])
  content    String
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model Notification {
  id         String    @id @default(cuid())
  userId     String?
  user       User?     @relation(fields: [userId], references: [id])
  businessId String?
  business   Business? @relation(fields: [businessId], references: [id])
  type       String
  title      String
  body       String
  isRead     Boolean   @default(false)
  createdAt  DateTime  @default(now())
}

model CarListing {
  id             String   @id @default(cuid())
  businessId     String
  business       Business @relation(fields: [businessId], references: [id])
  make           String
  model          String
  year           Int
  mileage        Int
  price          Float
  condition      String
  color          String?
  transmission   String?
  fuelType       String?
  numberOfOwners Int?
  description    String?
  images         String[]
  isAvailable    Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model ProfileView {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  viewerId   String?
  viewerIp   String?
  viewedAt   DateTime @default(now())

  @@index([businessId])
  @@index([viewedAt])
}
